server {
    listen 80;
    server_name zingcargo.com www.zingcargo.com;

    location /static/ {
        alias /var/www/tracking_web/staticfiles/;
    }

    location / {
        include proxy_params;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://unix:/var/www/tracking_web/tracking_web.sock;
    }
}
